# ================================================
# skill-generator 环境变量配置
# 复制此文件为 .env 并填入你的配置
# ================================================

# --- 应用设置 ---
APP_NAME=skill-generator
DEBUG=true
HOST=0.0.0.0
PORT=8000

# --- 数据库 ---
DATABASE_URL=sqlite:///./data/skills.db

# ================================================
# LLM API 设置
# ================================================
#
# 支持三种模式：
#
# 【推荐】DeepSeek（兼容 OpenAI 格式，价格极低，注册即送免费额度）
#   1. 注册: https://platform.deepseek.com
#   2. 创建 API Key
#   3. 填入以下配置：
#
# LLM_PROVIDER=deepseek
# OPENAI_API_KEY=sk-your-deepseek-key-here
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
#
# ------------------------------------------------
#
# OpenAI 官方 API
#
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini
#
# ------------------------------------------------
#
# Mock 模式（无需 API Key，生成模板文档，适合本地演示）
#
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=deepseek-chat

# --- 爬虫开关 ---
CRAWL_GITHUB_ENABLED=true
CRAWL_HACKERNEWS_ENABLED=true
CRAWL_DEVTO_ENABLED=true
CRAWL_PRODUCTHUNT_ENABLED=true
CRAWL_SKILLHUB_ENABLED=true

# --- 调度器设置 ---
SCHEDULER_ENABLED=true
SCHEDULER_HOUR=8
SCHEDULER_MINUTE=0
SCHEDULER_TIMEZONE=Asia/Shanghai

# --- 文档生成 ---
DOC_GEN_CONCURRENCY=5
